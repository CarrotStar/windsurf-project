# ============================================================
# Grid Trading Bot - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---- Exchange Settings ----
EXCHANGE=binance
API_KEY=your_exchange_api_key
API_SECRET=your_exchange_api_secret

# Use testnet/sandbox (true = paper trading on testnet, false = live)
TESTNET=true

# Paper trading mode: simulate orders locally without sending to exchange
# true = fully simulated (no exchange account needed, uses real prices)
# false = real orders on exchange (requires API keys)
PAPER_TRADING=true

# Market type: 'spot' or 'future' (Binance USDⓈ-M Futures)
MARKET_TYPE=future
# Futures leverage (1 = no leverage, max depends on symbol)
LEVERAGE=1

# ---- Grid Trading Parameters ----
# Comma-separated list of symbols to trade simultaneously
SYMBOLS=BTC/USDT,ETH/USDT,BNB/USDT,SOL/USDT,DOGE/USDT

# Default fallback values (used if per-symbol vars below are not set)
LOWER_PRICE=0
UPPER_PRICE=999999
GRID_COUNT=10
INVESTMENT=200

# Per-symbol overrides: format is <SYMBOL_USDT>_LOWER / _UPPER / _GRID_COUNT / _INVESTMENT
BTC_USDT_LOWER=68000
BTC_USDT_UPPER=76000
BTC_USDT_GRID_COUNT=10
BTC_USDT_INVESTMENT=200

ETH_USDT_LOWER=2000
ETH_USDT_UPPER=2500
ETH_USDT_GRID_COUNT=10
ETH_USDT_INVESTMENT=200

BNB_USDT_LOWER=550
BNB_USDT_UPPER=700
BNB_USDT_GRID_COUNT=10
BNB_USDT_INVESTMENT=200

SOL_USDT_LOWER=70
SOL_USDT_UPPER=100
SOL_USDT_GRID_COUNT=10
SOL_USDT_INVESTMENT=200

DOGE_USDT_LOWER=0.07
DOGE_USDT_UPPER=0.12
DOGE_USDT_GRID_COUNT=10
DOGE_USDT_INVESTMENT=200

# ---- Telegram Bot ----
# Create a bot via @BotFather on Telegram to get the token
TELEGRAM_TOKEN=your_telegram_bot_token
# Get your chat ID by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ---- Google Sheets ----
# Path to your Google Service Account JSON key file (in credentials/ folder)
GOOGLE_SHEETS_JSON_KEY=credentials/botgear-14d5aa6bb97f.json
# Option A: Spreadsheet ID from URL (recommended)
# https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
GOOGLE_SHEET_ID=
# Option B: Spreadsheet name (bot will search Drive — leave GOOGLE_SHEET_ID empty)
GOOGLE_SHEET_NAME=bot grid trading
# Worksheet (tab) name where trades are logged
GOOGLE_WORKSHEET_NAME=transactions

# ---- AWS RDS PostgreSQL ----
# Endpoint: found in AWS Console → RDS → Databases → your instance → Connectivity
# Free Tier: db.t3.micro | PostgreSQL 16 | 20 GB SSD | 750 hrs/month
DB_HOST=gridtrading-db.cposi6soknq8.ap-southeast-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=gridtrading
DB_USER=gridbot
DB_PASSWORD=GridBot2024!
# RDS enforces SSL by default — keep 'require' unless you explicitly disable it
DB_SSL_MODE=require

# ---- Risk Management ----
# Stop bot automatically if cumulative loss exceeds X% of investment
# e.g. 20 = stop when loss > $200 on a $1000 investment
MAX_LOSS_PCT=20

# ---- Bot Settings ----
# How often to check for filled orders (seconds)
CHECK_INTERVAL=30
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
